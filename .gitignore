# =============================================================================
# Global Gitignore for MIAFIN Project
# =============================================================================

# -----------------------------------------------------------------------------
# OS / Editor / IDE
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
.project
.classpath
.settings/
*.iml
*.code-workspace

# -----------------------------------------------------------------------------
# Secrets & Environment
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
.envrc
*.pem
*.key
*.crt
*.pfx
*.p12
secrets.yaml
secrets.yml
secrets.json
secrets.toml
!example.env
!.env.example

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/
log/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
bun-debug.log*

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/
vendor/

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
dist/
build/
out/
target/
*.exe
*.dll
*.so
*.dylib

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
*.lcov

# -----------------------------------------------------------------------------
# Temporary files
# -----------------------------------------------------------------------------
tmp/
temp/
*.tmp
.cache/

# =============================================================================
# Go (Backend)
# =============================================================================

# Binaries for programs and plugins
/backend/*.exe
/backend/*.exe~
/backend/*.dll
/backend/*.so
/backend/*.dylib
/backend/bin/
/backend/dist/

# Test binary, built with `go test -c`
/backend/*.test

# Output of the go coverage tool
/backend/*.out

# Go workspace file
/backend/go.work
/backend/go.work.sum

# Go vendor directory (if used)
/backend/vendor/

# Go build cache
/backend/.go-cache/

# =============================================================================
# SvelteKit / Bun (Frontend)
# =============================================================================

# Dependencies
/frontend/node_modules/
/frontend/.pnp
/frontend/.pnp.js

# Build outputs
/frontend/.svelte-kit/
/frontend/build/
/frontend/dist/
/frontend/package/

# Environment variables
/frontend/.env
/frontend/.env.local
/frontend/.env.*.local

# Testing
/frontend/coverage/

# Vite
/frontend/.vite/

# =============================================================================
# Docker
# =============================================================================

.dockerignore
docker-compose.override.yml

# =============================================================================
# Deployment
# =============================================================================

*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl
*.tfvars
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Kubernetes
*.kubeconfig
kubeconfig

# =============================================================================
# Misc
# =============================================================================

# Local notes
TODO.local.md
NOTES.local.md

# Generated documentation
docs/generated/

# Backup files
*.bak
*.backup
